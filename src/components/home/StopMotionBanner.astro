---
// Återanvändbar "bård"-sektion: sömlös video-loop som dämpad bakgrund med
// navy-overlay + ljus rubrik/underrad. Respekterar base-path och
// prefers-reduced-motion (visar poster i stället för video vid minskad rörelse).
// Props: video, poster (filnamn i public/), title, subtitle, label (valfri aria-label).
const { video, poster, title, subtitle, label } = Astro.props;
const base = import.meta.env.BASE_URL;
const posterSrc = base + poster;
const videoSrc = base + video;
---

<section class="sm-section" aria-label={label || title}>
  <div class="stopmotion">
    <video
      class="sm-video sm-feather"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="auto"
      poster={posterSrc}
      aria-hidden="true"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>

    <img class="sm-poster sm-feather" src={posterSrc} alt="" aria-hidden="true" />
  </div>

  <div class="sm-caption">
    <h2 class="sm-title">{title}</h2>
    <p class="sm-sub">{subtitle}</p>
  </div>
</section>

<script>
  // Tvinga autoplay på iOS/Android. Autoplay är ALLTID default (ingen
  // reduced-motion-blockering – det stoppade uppspelning på mobiler med
  // "Minska rörelse" på). Poster visas bara vid absolut fel (error-event).
  // Spelar både vid mount OCH när bården faktiskt syns (IntersectionObserver),
  // så .play() aldrig körs för tidigt. Hanterar flera bårdar på samma sida.
  const setupBanner = (root) => {
    const v = root.querySelector('.sm-video');
    if (!v) return;
    const tryPlay = () => {
      v.muted = true;
      v.setAttribute('muted', '');         // iOS kräver attributet, inte bara propen
      v.playsInline = true;
      v.setAttribute('playsinline', '');
      const p = v.play();
      if (p && p.catch) p.catch(() => {}); // svälj transienta fel, retry sker nedan
    };
    tryPlay();
    v.addEventListener('loadeddata', tryPlay, { once: true });
    v.addEventListener('canplay', tryPlay, { once: true });
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) tryPlay(); });
      }, { threshold: 0.2 });
      io.observe(root);
    }
    // Absolut undantag: videon kan inte laddas alls → visa poster
    v.addEventListener('error', () => root.classList.add('sm-fallback'), { once: true });
  };
  document.querySelectorAll('.stopmotion').forEach(setupBanner);
</script>

<style>
  /* Yttre sektion: navy bakgrund + vertikal luft. Horisontell padding ger gapet
     runt kortet, så ramen ALDRIG når viewportkanten (ingen söm / ingen overflow).
     box-sizing: border-box (Tailwind preflight) → paddingen spiller inte över 100%. */
  .sm-section {
    background: #020617;
    padding: 2.5rem 1rem;
  }
  @media (min-width: 640px) {
    .sm-section {
      padding: 3.5rem 1.5rem;
    }
  }

  /* Container: centrerad inom max-bredd. INGEN ram/ring/skugga/rundade hörn –
     feather-masken (.sm-feather) tonar ut alla fyra kanter mot navy-bakgrunden.
     Högre 4:3-crop på mobil (ingen platt remsa); 16:9 från sm och uppåt. */
  .stopmotion {
    position: relative;
    max-width: 72rem;
    margin: 0 auto;
    aspect-ratio: 4 / 3;
    background: #020617;
    isolation: isolate;
  }
  @media (min-width: 640px) {
    .stopmotion {
      aspect-ratio: 16 / 9;
    }
  }

  .sm-video,
  .sm-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Inga inbyggda kontroller/play-knapp ska kunna fångas */
    pointer-events: none;
  }

  /* Poster visas bara som fallback (reduced-motion eller nekad autoplay) */
  .sm-poster {
    display: none;
  }

  /* Fallback: om autoplay nekas (sätts av scriptet) – visa poster i stället */
  .stopmotion.sm-fallback .sm-video {
    display: none;
  }
  .stopmotion.sm-fallback .sm-poster {
    display: block;
  }

  /* Feather-fade på ALLA fyra kanter – EXAKT samma teknik som Om oss-bilden.
     Klippet uppenbaras ur navy-bakgrunden, ingen synlig ram. Mitten 100% intakt
     (opak ut till ~88/90%, bara yttersta ~10–12% tonar ut). */
  .sm-feather {
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 10%, #000 90%, transparent 100%);
    mask-image:
      linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 10%, #000 90%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
    mask-mode: alpha;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }

  /* Text UNDER videon (inte overlay): centrerad caption med luft till klippet. */
  .sm-caption {
    max-width: 72rem;
    margin: clamp(1.25rem, 3vw, 1.75rem) auto 0;
    padding: 0 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .sm-title {
    font-family: 'Bebas Neue', system-ui, sans-serif;
    color: #ffffff;
    font-size: clamp(1.75rem, 5vw, 3.25rem);
    letter-spacing: 0.02em;
    line-height: 1.05;
    max-width: 58rem;
    text-shadow: 0 2px 30px rgba(2, 6, 23, 0.55);
  }

  .sm-sub {
    margin: 0;
    max-width: 42rem;
    color: #e2e8f0;
    font-size: clamp(0.95rem, 2.2vw, 1.2rem);
    font-weight: 400;
    line-height: 1.5;
    text-shadow: 0 1px 16px rgba(2, 6, 23, 0.6);
  }
</style>
