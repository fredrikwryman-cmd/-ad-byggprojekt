---
// Fristående "bård"-sektion på startsidan: sömlös stop motion-loop som dämpad
// bakgrund med navy-overlay och en ljus rubrik. Respekterar base-path och
// prefers-reduced-motion (visar poster i stället för video vid minskad rörelse).
const base = import.meta.env.BASE_URL;
const poster = base + 'byggplats-stopmotion-poster.jpg';
const video = base + 'byggplats-stopmotion.mp4';
---

<section class="stopmotion" aria-label="AD Byggprojekt – från projektledning till färdig byggnad">
  <video
    class="sm-video"
    autoplay
    muted
    loop
    playsinline
    webkit-playsinline
    preload="auto"
    poster={poster}
    aria-hidden="true"
  >
    <source src={video} type="video/mp4" />
  </video>

  <img class="sm-poster" src={poster} alt="" aria-hidden="true" />

  <div class="sm-overlay"></div>

  <div class="sm-inner">
    <h2 class="sm-title">HELHETSANSVAR FRÅN FÖRSTA SPADTAGET</h2>
    <p class="sm-sub">Vi samordnar, kvalitetssäkrar och driver projektet i mål — i tid och inom budget.</p>
  </div>
</section>

<script>
  // Tvinga autoplay på iOS/Android (muted + playsInline + programmatisk play).
  // Vid minskad rörelse: spela inte. Vid nekad autoplay: visa poster i stället.
  const root = document.querySelector('.stopmotion');
  const v = root?.querySelector('.sm-video');
  if (root && v) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      v.removeAttribute('autoplay');
      try { v.pause(); } catch (e) {}
    } else {
      const start = () => {
        v.muted = true;
        v.setAttribute('muted', '');
        v.playsInline = true;
        const p = v.play();
        if (p && p.catch) {
          p.catch(() => { root.classList.add('sm-fallback'); });
        }
      };
      start();
      v.addEventListener('canplay', start, { once: true });
      v.addEventListener('loadeddata', start, { once: true });
    }
  }
</script>

<style>
  .stopmotion {
    position: relative;
    width: 100%;
    /* 16:9 så hela videobilden (1280x720) ryms utan beskärning, på alla bredder */
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #020617;
    isolation: isolate;
  }

  .sm-video,
  .sm-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Inga inbyggda kontroller/play-knapp ska kunna fångas */
    pointer-events: none;
  }

  /* Poster visas bara som fallback (reduced-motion eller nekad autoplay) */
  .sm-poster {
    display: none;
  }

  /* Fallback: om autoplay nekas (sätts av scriptet) – visa poster i stället */
  .stopmotion.sm-fallback .sm-video {
    display: none;
  }
  .stopmotion.sm-fallback .sm-poster {
    display: block;
  }

  .sm-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: #020617;
    opacity: 0.64;
  }

  .sm-inner {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    padding: 0 1.5rem;
    text-align: center;
  }

  .sm-title {
    font-family: 'Bebas Neue', system-ui, sans-serif;
    color: #ffffff;
    font-size: clamp(1.75rem, 5vw, 3.25rem);
    letter-spacing: 0.02em;
    line-height: 1.05;
    max-width: 58rem;
    text-shadow: 0 2px 30px rgba(2, 6, 23, 0.55);
  }

  .sm-sub {
    margin: 0;
    max-width: 42rem;
    color: #e2e8f0;
    font-size: clamp(0.95rem, 2.2vw, 1.2rem);
    font-weight: 400;
    line-height: 1.5;
    text-shadow: 0 1px 16px rgba(2, 6, 23, 0.6);
  }

  @media (prefers-reduced-motion: reduce) {
    .sm-video {
      display: none;
    }
    .sm-poster {
      display: block;
    }
  }
</style>
