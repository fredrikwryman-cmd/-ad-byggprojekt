---
// Återanvändbar "bård"-sektion: sömlös video-loop som dämpad bakgrund med
// navy-overlay + ljus rubrik/underrad. Respekterar base-path och
// prefers-reduced-motion (visar poster i stället för video vid minskad rörelse).
// Props: video, poster (filnamn i public/), title, subtitle, label (valfri aria-label).
const { video, poster, title, subtitle, label } = Astro.props;
const base = import.meta.env.BASE_URL;
const posterSrc = base + poster;
const videoSrc = base + video;
---

<section class="sm-section" aria-label={label || title}>
  <div class="stopmotion">
    <video
      class="sm-video"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="auto"
      poster={posterSrc}
      aria-hidden="true"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>

    <img class="sm-poster" src={posterSrc} alt="" aria-hidden="true" />

    <div class="sm-overlay"></div>
    <div class="sm-fade sm-fade--top" aria-hidden="true"></div>
    <div class="sm-fade sm-fade--bottom" aria-hidden="true"></div>

    <div class="sm-inner">
      <h2 class="sm-title">{title}</h2>
      <p class="sm-sub">{subtitle}</p>
    </div>
  </div>
</section>

<script>
  // Tvinga autoplay på iOS/Android (muted + playsInline + programmatisk play).
  // Vid minskad rörelse: spela inte. Vid nekad autoplay: visa poster i stället.
  // Hanterar ALLA bårdar på sidan (kan finnas flera instanser).
  const setupBanner = (root) => {
    const v = root.querySelector('.sm-video');
    if (!v) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      v.removeAttribute('autoplay');
      try { v.pause(); } catch (e) {}
      return;
    }
    const start = () => {
      v.muted = true;
      v.setAttribute('muted', '');
      v.playsInline = true;
      const p = v.play();
      if (p && p.catch) {
        p.catch(() => { root.classList.add('sm-fallback'); });
      }
    };
    start();
    v.addEventListener('canplay', start, { once: true });
    v.addEventListener('loadeddata', start, { once: true });
  };
  document.querySelectorAll('.stopmotion').forEach(setupBanner);
</script>

<style>
  /* Yttre sektion: navy bakgrund + vertikal luft. Horisontell padding ger gapet
     runt kortet, så ramen ALDRIG når viewportkanten (ingen söm / ingen overflow).
     box-sizing: border-box (Tailwind preflight) → paddingen spiller inte över 100%. */
  .sm-section {
    background: #020617;
    padding: 2.5rem 1rem;
  }
  @media (min-width: 640px) {
    .sm-section {
      padding: 3.5rem 1.5rem;
    }
  }

  /* Inramad container: centrerad inom max-bredd, rundade hörn, tunn kant, mjuk skugga.
     Högre 4:3-crop på mobil (ingen platt remsa); 16:9 från sm och uppåt. */
  .stopmotion {
    position: relative;
    max-width: 72rem;
    margin: 0 auto;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 18px 40px -12px rgba(0, 0, 0, 0.5);
    background: #020617;
    isolation: isolate;
  }
  @media (min-width: 640px) {
    .stopmotion {
      aspect-ratio: 16 / 9;
    }
  }

  .sm-video,
  .sm-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Inga inbyggda kontroller/play-knapp ska kunna fångas */
    pointer-events: none;
  }

  /* Poster visas bara som fallback (reduced-motion eller nekad autoplay) */
  .sm-poster {
    display: none;
  }

  /* Fallback: om autoplay nekas (sätts av scriptet) – visa poster i stället */
  .stopmotion.sm-fallback .sm-video {
    display: none;
  }
  .stopmotion.sm-fallback .sm-poster {
    display: block;
  }

  .sm-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: #020617;
    opacity: 0.64;
  }

  /* Subtila fade-kanter i topp/botten – mjukar upp den hårda kanten */
  .sm-fade {
    position: absolute;
    left: 0;
    right: 0;
    height: 11%;
    z-index: 1;
    pointer-events: none;
  }
  .sm-fade--top {
    top: 0;
    background: linear-gradient(to bottom, #020617, transparent);
  }
  .sm-fade--bottom {
    bottom: 0;
    background: linear-gradient(to top, #020617, transparent);
  }

  .sm-inner {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    padding: 0 1.5rem;
    text-align: center;
  }

  .sm-title {
    font-family: 'Bebas Neue', system-ui, sans-serif;
    color: #ffffff;
    font-size: clamp(1.75rem, 5vw, 3.25rem);
    letter-spacing: 0.02em;
    line-height: 1.05;
    max-width: 58rem;
    text-shadow: 0 2px 30px rgba(2, 6, 23, 0.55);
  }

  .sm-sub {
    margin: 0;
    max-width: 42rem;
    color: #e2e8f0;
    font-size: clamp(0.95rem, 2.2vw, 1.2rem);
    font-weight: 400;
    line-height: 1.5;
    text-shadow: 0 1px 16px rgba(2, 6, 23, 0.6);
  }

  @media (prefers-reduced-motion: reduce) {
    .sm-video {
      display: none;
    }
    .sm-poster {
      display: block;
    }
  }
</style>
