---
// Återanvändbar "bård"-sektion: sömlös video-loop som dämpad bakgrund med
// navy-overlay + ljus rubrik/underrad. Respekterar base-path och
// prefers-reduced-motion (visar poster i stället för video vid minskad rörelse).
// Props: video, poster (filnamn i public/), title, subtitle, label (valfri aria-label).
const { video, poster, title, subtitle, label } = Astro.props;
const base = import.meta.env.BASE_URL;
const posterSrc = base + poster;
const videoSrc = base + video;
---

<section class="sm-section" aria-label={label || title}>
  <div class="sm-stage">
    <div class="stopmotion sm-feather">
      <video
        class="sm-video"
        autoplay
        muted
        loop
        playsinline
        webkit-playsinline
        preload="auto"
        poster={posterSrc}
        aria-hidden="true"
      >
        <source src={videoSrc} type="video/mp4" />
      </video>

      <img class="sm-poster" src={posterSrc} alt="" aria-hidden="true" />
    </div>

    {/* Paus/spela-kontroll (WCAG 2.2.2). Ligger utanför feather-masken så den
        inte tonas bort i hörnet. Tangentbordsåtkomlig via <button>. */}
    <button class="sm-toggle" type="button" aria-label="Pausa video">
      <svg class="sm-ic-pause" aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"></rect><rect x="14" y="5" width="4" height="14" rx="1"></rect></svg>
      <svg class="sm-ic-play" aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
    </button>
  </div>

  <div class="sm-caption">
    <h2 class="sm-title">{title}</h2>
    <p class="sm-sub">{subtitle}</p>
  </div>
</section>

<script>
  // Bulletproof muted inline-autoplay (iOS/Android). Ingen reduced-motion-
  // blockering. Masken ligger på wrappern (.stopmotion), inte på <video> –
  // mask direkt på video kan göra klippet osynligt/icke-spelande på iOS.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const toggleFor = (v) => {
    const stage = v.closest('.sm-stage');
    return stage ? stage.querySelector('.sm-toggle') : null;
  };

  // Synka knappens ikon + aria-label mot videons faktiska tillstånd.
  const syncBtn = (v) => {
    const btn = toggleFor(v);
    if (!btn) return;
    const paused = v.paused;
    btn.classList.toggle('is-paused', paused);
    btn.setAttribute('aria-label', paused ? 'Spela video' : 'Pausa video');
  };

  const play = (v) => {
    // Respektera både prefers-reduced-motion och ett medvetet pausval.
    if (v.dataset.userPaused === 'true') return;
    v.muted = true;
    v.defaultMuted = true;
    v.setAttribute('muted', '');
    v.setAttribute('playsinline', '');
    v.setAttribute('webkit-playsinline', '');
    const p = v.play();
    if (p && p.catch) p.catch(() => {});
    syncBtn(v);
  };

  const vids = Array.prototype.slice.call(document.querySelectorAll('.sm-video'));
  vids.forEach((v) => {
    const btn = toggleFor(v);
    if (btn) {
      btn.addEventListener('click', () => {
        if (v.paused) { v.dataset.userPaused = 'false'; play(v); }
        else { v.dataset.userPaused = 'true'; v.pause(); }
        syncBtn(v);
      });
    }

    v.addEventListener('play', () => syncBtn(v));
    v.addEventListener('pause', () => syncBtn(v));
    v.addEventListener('error', () => {
      const root = v.closest('.stopmotion');
      if (root) root.classList.add('sm-fallback');
    }, { once: true });

    if (reduced) {
      // Rörelse av som default: starta pausad, postern visas, användaren kan spela.
      v.dataset.userPaused = 'true';
      syncBtn(v);
      return;
    }

    play(v);
    v.addEventListener('loadeddata', () => play(v), { once: true });
    v.addEventListener('canplay', () => play(v), { once: true });
    if ('IntersectionObserver' in window) {
      new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) play(v); });
      }, { threshold: 0.15 }).observe(v);
    }
  });

  // Sista utväg: om kall autoplay blockeras (t.ex. iOS strömsparläge/Low Data),
  // starta vid första användarinteraktion – då spelar klippen garanterat.
  // (Hoppas över vid reduced-motion och för videor som användaren själv pausat.)
  if (!reduced) {
    const kick = () => vids.forEach(play);
    ['touchstart', 'pointerdown', 'scroll', 'click'].forEach((evt) =>
      window.addEventListener(evt, kick, { once: true, passive: true }));
  }
</script>

<style>
  /* Yttre sektion: navy bakgrund + vertikal luft. Horisontell padding ger gapet
     runt kortet, så ramen ALDRIG når viewportkanten (ingen söm / ingen overflow).
     box-sizing: border-box (Tailwind preflight) → paddingen spiller inte över 100%. */
  .sm-section {
    background: #020617;
    padding: 2.5rem 1rem;
  }
  @media (min-width: 640px) {
    .sm-section {
      padding: 3.5rem 1.5rem;
    }
  }

  /* Container: centrerad inom max-bredd. INGEN ram/ring/skugga/rundade hörn –
     feather-masken (.sm-feather) tonar ut alla fyra kanter mot navy-bakgrunden.
     Högre 4:3-crop på mobil (ingen platt remsa); 16:9 från sm och uppåt. */
  /* Scen runt videon: samma bredd/centrering som klippet, men UTAN feather-mask,
     så paus-knappen kan ligga i hörnet utan att tonas bort. */
  .sm-stage {
    position: relative;
    max-width: 72rem;
    margin: 0 auto;
  }

  .sm-toggle {
    position: absolute;
    bottom: clamp(0.75rem, 2.2vw, 1.25rem);
    right: clamp(0.75rem, 2.2vw, 1.25rem);
    z-index: 3;
    width: 2.5rem;
    height: 2.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(2, 6, 23, 0.55);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
  }
  .sm-toggle:hover {
    background: rgba(2, 6, 23, 0.82);
    transform: scale(1.06);
  }
  .sm-toggle:focus-visible {
    outline: 3px solid #60a5fa;
    outline-offset: 2px;
  }
  .sm-toggle svg {
    width: 18px;
    height: 18px;
    display: block;
  }
  .sm-toggle .sm-ic-play { display: none; }
  .sm-toggle.is-paused .sm-ic-pause { display: none; }
  .sm-toggle.is-paused .sm-ic-play { display: block; }

  .stopmotion {
    position: relative;
    max-width: 72rem;
    margin: 0 auto;
    aspect-ratio: 4 / 3;
    background: #020617;
    isolation: isolate;
    /* Egen GPU-/stacking-kontext: krävs för att mask på wrappern inte ska
       svartlägga/diskvalificera videon från iOS autoplay (visible-on-screen). */
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
  @media (min-width: 640px) {
    .stopmotion {
      aspect-ratio: 16 / 9;
    }
  }

  .sm-video,
  .sm-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Inga inbyggda kontroller/play-knapp ska kunna fångas */
    pointer-events: none;
  }

  /* Poster visas bara som fallback (reduced-motion eller nekad autoplay) */
  .sm-poster {
    display: none;
  }

  /* Fallback: om autoplay nekas (sätts av scriptet) – visa poster i stället */
  .stopmotion.sm-fallback .sm-video {
    display: none;
  }
  .stopmotion.sm-fallback .sm-poster {
    display: block;
  }

  /* Feather-fade på ALLA fyra kanter – EXAKT samma teknik som Om oss-bilden.
     Klippet uppenbaras ur navy-bakgrunden, ingen synlig ram. Mitten 100% intakt
     (opak ut till ~88/90%, bara yttersta ~10–12% tonar ut). */
  .sm-feather {
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 10%, #000 72%, transparent 100%);
    mask-image:
      linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 10%, #000 72%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
    mask-mode: alpha;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }

  /* Text UNDER videon (inte overlay): centrerad caption med luft till klippet. */
  .sm-caption {
    max-width: 72rem;
    margin: clamp(1.25rem, 3vw, 1.75rem) auto 0;
    padding: 0 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .sm-title {
    font-family: 'Bebas Neue', system-ui, sans-serif;
    color: #ffffff;
    font-size: clamp(1.75rem, 5vw, 3.25rem);
    letter-spacing: 0.02em;
    line-height: 1.05;
    max-width: 58rem;
    text-shadow: 0 2px 30px rgba(2, 6, 23, 0.55);
  }

  .sm-sub {
    margin: 0;
    max-width: 42rem;
    color: #e2e8f0;
    font-size: clamp(0.95rem, 2.2vw, 1.2rem);
    font-weight: 400;
    line-height: 1.5;
    text-shadow: 0 1px 16px rgba(2, 6, 23, 0.6);
  }
</style>
