---
// Self-hostade typsnitt (ersätter render-blockerande Google Fonts-@import).
// font-display: swap är inbyggt i @fontsource-filerna.
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/bebas-neue/400.css';
import AndreasChat from '../components/chat/AndreasChat.jsx';

const {
  title = 'AD Byggprojekt Stockholm AB',
  description,
  ogImage: ogImageProp,
  ogType = 'website',
  ogImageAlt = 'AD Byggprojekt Stockholm AB – byggarbetsplats i solnedgång med företagets skylt.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteRoot = new URL(import.meta.env.BASE_URL, Astro.site).href;
const defaultOgImage = `${import.meta.env.BASE_URL}og-hero.jpg`;
const usingDefaultOgImage = !ogImageProp;
const ogImage = new URL(ogImageProp || defaultOgImage, Astro.site).href;
const logoURL = new URL(`${import.meta.env.BASE_URL}favicon-ad.png`, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': siteRoot,
  name: 'AD Byggprojekt Stockholm AB',
  url: siteRoot,
  logo: logoURL,
  image: ogImage,
  telephone: '+46704629943',
  email: 'andreas@adbyggprojekt.se',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Kantarellvägen 4',
    postalCode: '184 34',
    addressLocality: 'Åkersberga',
    addressRegion: 'Stockholms län',
    addressCountry: 'SE',
  },
  areaServed: [
    { '@type': 'City', name: 'Stockholm' },
    { '@type': 'City', name: 'Åkersberga' },
    { '@type': 'City', name: 'Uppsala' },
  ],
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:00',
    closes: '16:00',
  },
  identifier: { '@type': 'PropertyValue', name: 'Organisationsnummer', value: '559131-8695' },
  sameAs: ['https://se.linkedin.com/in/andreas-dahlgren-067948105'],
};
---
<!DOCTYPE html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Content-Security-Policy (GitHub Pages tillåter ej egna HTTP-headers → meta).
         Tillåter allt sajten använder: self för script/style/img/font/media,
         web3forms-POST (formulär + chatt), samt googletagmanager/google-analytics
         så GA4 kan slås på senare utan att brytas. 'unsafe-inline' krävs av
         Astro/Tailwind/Framer Motion (inline <style>) och Astros define:vars-script. -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; object-src 'none'; frame-src 'none'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://*.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://www.google-analytics.com https://*.google-analytics.com; font-src 'self'; media-src 'self'; connect-src 'self' https://api.web3forms.com https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com; form-action 'self' https://api.web3forms.com"
    />

    <meta name="description" content={description} />
    <meta name="theme-color" content="#020617" />
    <meta name="robots" content="index, follow" />

    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="48x48" href={`${import.meta.env.BASE_URL}favicon-48.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}favicon-48.png`} />

    <title>{title}</title>

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="AD Byggprojekt Stockholm AB" />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    {usingDefaultOgImage && (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Strukturerad data (LocalBusiness) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <!-- Analys (förberedd, ej aktiv):
         När en egen domän är kopplad kan webbanalys läggas till här.
         Plausible rekommenderas (GDPR-vänlig, ingen cookie-banner behövs).
         Be assistenten om den exakta script-raden när domänen är på plats. -->

    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body
    class="bg-white text-[#020617] antialiased"
    style={`--bp-dark:url('${import.meta.env.BASE_URL}bg-blueprint-dark.jpg');--bp-light:url('${import.meta.env.BASE_URL}bg-blueprint-light.jpg')`}
  >
    <a href="#main" class="skip-link">Hoppa till innehåll</a>
    <slot />
    {/* Fråga Heidi TILLFÄLLIGT DOLD – avkommentera raden nedan (och knapparna i
        Navbar.jsx) för att återaktivera chatten: */}
    {/* <AndreasChat client:idle /> */}
  </body>
</html>
