---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.jsx';
import HeroSection from '../components/home/HeroSection.jsx';
import MarqueeSection from '../components/home/MarqueeSection.jsx';
import StatsSection from '../components/home/StatsSection.jsx';
import ProjectsSection from '../components/projects/ProjectsSection.jsx';
import ServicesSection from '../components/services/ServicesSection.jsx';
import StopMotionBanner from '../components/home/StopMotionBanner.astro';
import AboutSection from '../components/about/AboutSection.jsx';
// OMDÖMEN AVAKTIVERADE: modulen är dold tills riktiga kundomdömen finns.
// Aktivera igen genom att (1) lägga in äkta omdömen i TestimonialsSection.jsx
// och (2) avkommentera raden nedan samt <TestimonialsSection> längre ner.
// import TestimonialsSection from '../components/home/TestimonialsSection.jsx';
import ContactSection from '../components/contact/ContactSection.jsx';
import FaqSection from '../components/home/FaqSection.jsx';
import Footer from '../components/layout/Footer.jsx';

const faqs = [
  ['Vilka områden arbetar ni i?', 'Vi är verksamma i Stockholm med omnejd – hela Storstockholm samt Uppsala. Hör av dig om du är osäker på om vi täcker just din ort.'],
  ['Är det första mötet kostnadsfritt?', 'Ja. Vi börjar alltid med ett förutsättningslöst möte där vi lyssnar på dina idéer och gör en första bedömning – helt utan kostnad eller förpliktelse.'],
  ['Hur lång tid tar ett projekt?', 'Det beror helt på omfattningen. Du får alltid en realistisk tidsplan i offerten, och vi håller dig uppdaterad om status genom hela projektet.'],
  ['Kan jag använda ROT-avdrag?', 'För privatpersoner kan ROT-avdrag oftast användas vid renovering och ombyggnad, och vi hjälper dig att hantera avdraget direkt på fakturan. Hör av dig så går vi igenom vad som gäller för just ditt projekt.'],
  ['Har ni F-skatt och försäkring?', 'Ja, vi är godkända för F-skatt och har ansvarsförsäkring. Du arbetar alltid med en seriös och trygg motpart.'],
  ['Hur fungerar priset?', 'Det vanligaste i våra uppdrag är löpande räkning med tät ekonomisk uppföljning, så att du alltid har koll på kostnaderna. När projektet är tydligt avgränsat kan vi även lämna fast pris. Vi går igenom upplägget tillsammans innan vi sätter igång.'],
  ['Vilken garanti gäller?', 'Vi lämnar garanti enligt branschens regler och dokumenterar arbetet vid överlämningen. Du får tydliga avtal och vet alltid vad som gäller.'],
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(([q, a]) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<Layout
  title="AD Byggprojekt Stockholm AB | Byggledning & projektledning i Stockholm"
  description="AD Byggprojekt Stockholm AB — erfaren byggledning, platsledning och projektledning i Stockholm. Vi styr ditt projekt i mål med kvalitet, arbetsmiljö och ekonomi i fokus."
>
  <Navbar client:idle />
  <main>
  <HeroSection client:idle />
  <div class="relative bg-[#020617] overflow-hidden isolate">
    <MarqueeSection />
    <StatsSection client:idle />
  </div>
  <ProjectsSection client:idle />
  <ServicesSection client:idle />
  <StopMotionBanner />
  <AboutSection client:idle />
  {/* OMDÖMEN dold tills riktiga finns – avkommentera nedan för att aktivera igen: */}
  {/* <TestimonialsSection client:idle /> */}
  <FaqSection client:idle />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
  <ContactSection client:idle />
  </main>
  <Footer />
</Layout>
