---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.jsx';
import Footer from '../components/layout/Footer.jsx';
import PageHeader from '../components/pages/PageHeader.jsx';
import StopMotionBanner from '../components/home/StopMotionBanner.astro';
import ServicesPage, { services } from '../components/pages/ServicesPage.jsx';

// Service-schema speglar exakt de tjänster som visas (samma källa som ServicesPage).
// CM-uppdrag utelämnas då det utförs av systerbolaget, inte AD Byggprojekt.
const siteRoot = new URL(import.meta.env.BASE_URL, Astro.site).href;
const servicesSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: services
    .filter((s) => !s.cm)
    .map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Service',
        name: s.title,
        serviceType: s.title,
        description: s.summary,
        areaServed: { '@type': 'City', name: 'Stockholm' },
        provider: {
          '@type': 'ProfessionalService',
          name: 'AD Byggprojekt Stockholm AB',
          url: siteRoot,
        },
      },
    })),
};
---

<Layout
  title="Våra tjänster | AD Byggprojekt Stockholm AB"
  description="AD Byggprojekt Stockholm AB erbjuder byggledning, platsledning, projektledning och rådgivning i Stockholm — vi styr ditt projekt i mål."
>
  <Navbar client:idle />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(servicesSchema)} />
  <main id="main">
  <PageHeader
    client:idle
    eyebrow="Vad vi gör"
    title="Våra tjänster"
    subtitle="Byggledning, platsledning och projektledning — vi styr ditt projekt i mål, från första idé till färdig överlämning."
  />
  <ServicesPage client:idle />
  </main>
  <Footer />
</Layout>
