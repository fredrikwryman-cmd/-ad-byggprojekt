---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar.jsx';
import Footer from '../../components/layout/Footer.jsx';
import { allProjects } from '../../data/projects.js';

export function getStaticPaths() {
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
const metaTitle = `${project.title} | AD Byggprojekt Stockholm AB`;
const metaDesc = project.description;

// Grann-projekt för pil-navigering (loopar runt så man kan bläddra igenom alla)
const idx = allProjects.findIndex((p) => p.slug === project.slug);
const prevProject = allProjects[(idx - 1 + allProjects.length) % allProjects.length];
const nextProject = allProjects[(idx + 1) % allProjects.length];

// Galleri-bilder – HELT separata från den redigerade hero-bilden (project.image).
// Tom array = ingen galleri-sektion visas.
const gallery = project.gallery || [];

// ===== Strukturerad data (kompletterar Layout:s ProfessionalService) =====
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteRoot = new URL(base, Astro.site).href;
const projektURL = new URL(base + 'projekt', Astro.site).href;
const projectImage = project.hasImage ? new URL(project.image, Astro.site).href : undefined;

// Projektet som ett verk – byggprojekt med faktiska data ur projects.js.
const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.title,
  description: project.longDescription || project.description,
  url: canonicalURL.href,
  ...(projectImage ? { image: projectImage } : {}),
  locationCreated: { '@type': 'Place', name: project.location },
  temporalCoverage: project.year,
  ...(project.client
    ? { sourceOrganization: { '@type': 'Organization', name: project.client } }
    : {}),
  about: project.category,
  creator: {
    '@type': 'Organization',
    name: 'AD Byggprojekt Stockholm AB',
    url: siteRoot,
  },
};

// Brödsmulor: Hem → Projekt → [Projektnamn] (absoluta URL:er).
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Hem', item: siteRoot },
    { '@type': 'ListItem', position: 2, name: 'Projekt', item: projektURL },
    { '@type': 'ListItem', position: 3, name: project.title, item: canonicalURL.href },
  ],
};
---

<Layout
  title={metaTitle}
  description={metaDesc}
  ogType="article"
  ogImage={project.hasImage ? project.image : undefined}
  ogImageAlt={project.hasImage ? project.title : undefined}
>
  <Navbar client:idle />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(projectSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <main id="main" class="pd">
    <section class="pd-hero">
      <div class="pd-hero-inner">
        <a href={base + 'projekt'} class="pd-back">&larr; Alla projekt</a>
        {project.hasImage && (
          <div class="pd-media">
            <img src={project.image} alt={project.title} width="1280" height="714" />
          </div>
        )}
        <div class="pd-badges">
          <span class="pd-cat">{project.category}</span>
          <span class="pd-year">{project.year}</span>
        </div>
        <h1>{project.title}</h1>
        <p class="pd-loc">{project.location} &middot; {project.client}</p>
      </div>
    </section>

    <section class="pd-body">
      <div class="pd-container">
        <div class="pd-grid">
          <div class="pd-desc">
            <h2>Om projektet</h2>
            <p>{project.longDescription}</p>
          </div>
          <aside class="pd-facts">
            <h3>Fakta</h3>
            <dl>
              {project.facts.map((f) => (
                <div class="pd-fact">
                  <dt>{f.label}</dt>
                  <dd>{f.value}</dd>
                </div>
              ))}
            </dl>
          </aside>
        </div>

        {gallery.length > 0 && (
          <div class="pd-gallery">
            <h2>Fler bilder från projektet</h2>
            <div class="pd-gallery-grid">
              {gallery.map((src, i) => (
                <button class="pd-gallery-item" type="button" aria-label={`Öppna bild ${i + 1} i större format`}>
                  <img src={src} alt={`${project.title} – bild ${i + 1}`} loading="lazy" />
                </button>
              ))}
            </div>
          </div>
        )}

        <div class="pd-cta">
          <h2>Vill du ha hjälp med ett liknande projekt?</h2>
          <p>Berätta om dina planer så återkommer vi med en kostnadsfri offert så snart vi kan.</p>
          <a href={base + 'kontakt'} class="btn-primary">Kontakta oss</a>
        </div>

        <nav class="pd-nav" aria-label="Bläddra mellan projekt">
          <a class="pd-nav-link pd-nav-prev" href={base + 'projekt/' + prevProject.slug} rel="prev">
            <span class="pd-nav-arrow" aria-hidden="true">&larr;</span>
            <span class="pd-nav-text">
              <span class="pd-nav-label">Föregående projekt</span>
              <span class="pd-nav-title">{prevProject.title}</span>
            </span>
          </a>
          <a class="pd-nav-link pd-nav-next" href={base + 'projekt/' + nextProject.slug} rel="next">
            <span class="pd-nav-text">
              <span class="pd-nav-label">Nästa projekt</span>
              <span class="pd-nav-title">{nextProject.title}</span>
            </span>
            <span class="pd-nav-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </nav>
      </div>
    </section>

    {gallery.length > 0 && (
      <div class="pd-lightbox" id="pd-lightbox" role="dialog" aria-modal="true" aria-label="Bildvisning" aria-hidden="true">
        <button class="pd-lb-close" data-lb-close type="button" aria-label="Stäng">&times;</button>
        <button class="pd-lb-nav pd-lb-prev" data-lb-prev type="button" aria-label="Föregående bild">&larr;</button>
        <img class="pd-lb-img" id="pd-lb-img" alt={project.title} />
        <button class="pd-lb-nav pd-lb-next" data-lb-next type="button" aria-label="Nästa bild">&rarr;</button>
        <div class="pd-lb-counter" id="pd-lb-counter"></div>
      </div>
    )}
  </main>

  <Footer />

  <script define:vars={{ galleryImages: gallery }}>
    // Lightbox – ENDAST för galleri-bilderna (hero-bilden ingår aldrig här).
    const lb = document.getElementById('pd-lightbox');
    if (lb && galleryImages.length) {
      const img = document.getElementById('pd-lb-img');
      const counter = document.getElementById('pd-lb-counter');
      let current = 0;
      const open = (i) => {
        current = (i + galleryImages.length) % galleryImages.length;
        img.src = galleryImages[current];
        counter.textContent = (current + 1) + ' / ' + galleryImages.length;
        lb.classList.add('open');
        lb.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };
      const close = () => {
        lb.classList.remove('open');
        lb.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };
      document.querySelectorAll('.pd-gallery-item').forEach((b, i) => {
        b.addEventListener('click', () => open(i));
      });
      lb.querySelector('[data-lb-close]').addEventListener('click', close);
      lb.querySelector('[data-lb-prev]').addEventListener('click', (e) => { e.stopPropagation(); open(current - 1); });
      lb.querySelector('[data-lb-next]').addEventListener('click', (e) => { e.stopPropagation(); open(current + 1); });
      lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
      document.addEventListener('keydown', (e) => {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') open(current - 1);
        else if (e.key === 'ArrowRight') open(current + 1);
      });
    }
  </script>
</Layout>

<style>
  .pd {
    background: #020617;
    color: #fff;
  }

  .pd-hero {
    padding: clamp(6.5rem, 6vw + 4rem, 7.5rem) clamp(1.25rem, 6vw, 6rem) clamp(1rem, 3vw, 2rem);
  }

  .pd-media {
    margin: 0 0 2rem;
    border-radius: 1.25rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0f172a;
    aspect-ratio: 16 / 9;
  }
  .pd-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pd-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 72rem;
    margin: 0 auto;
    width: 100%;
  }

  .pd-back {
    display: inline-block;
    color: #94a3b8;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.25s ease;
  }
  .pd-back:hover {
    color: #fff;
  }

  .pd-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .pd-cat {
    background: #0078d4;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
  }
  .pd-year {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
  }

  .pd-hero h1 {
    font-family: 'Bebas Neue', system-ui, sans-serif;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: 0.01em;
    margin: 0 0 0.6rem;
  }

  .pd-loc {
    color: #cbd5e1;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    font-weight: 500;
    margin: 0;
  }

  .pd-body {
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.25rem, 6vw, 6rem) clamp(3rem, 7vw, 6rem);
  }

  .pd-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .pd-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 900px) {
    .pd-grid {
      grid-template-columns: 1.6fr 1fr;
      gap: 4rem;
    }
  }

  .pd-desc h2,
  .pd-cta h2 {
    font-family: 'Bebas Neue', system-ui, sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0 0 1rem;
    letter-spacing: 0.01em;
  }

  .pd-desc p {
    color: #94a3b8;
    font-size: 1.0625rem;
    line-height: 1.8;
    margin: 0;
  }

  .pd-facts {
    background: #0f172a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 4vw, 2rem);
    align-self: start;
  }

  .pd-facts h3 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4a9eff;
    margin: 0 0 1.25rem;
  }

  .pd-facts dl {
    margin: 0;
  }

  .pd-fact {
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  .pd-fact:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .pd-fact:first-child {
    padding-top: 0;
  }

  .pd-fact dt {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
    margin-bottom: 0.3rem;
  }
  .pd-fact dd {
    margin: 0;
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .pd-cta {
    margin-top: clamp(2.5rem, 6vw, 4.5rem);
    padding: clamp(2rem, 5vw, 3.5rem);
    background:
      radial-gradient(600px 240px at 50% 0%, rgba(0, 120, 212, 0.18), transparent),
      #0f172a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1.5rem;
    text-align: center;
  }

  .pd-cta p {
    color: #94a3b8;
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 34rem;
    margin: 0 auto 1.75rem;
  }

  .pd-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: clamp(2rem, 5vw, 3.5rem);
  }
  @media (max-width: 640px) {
    .pd-nav {
      grid-template-columns: 1fr;
    }
  }

  .pd-nav-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.4rem;
    background: #0f172a;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    text-decoration: none;
    transition: border-color 0.25s ease, transform 0.25s ease, background 0.25s ease;
  }
  .pd-nav-link:hover {
    border-color: rgba(0, 120, 212, 0.5);
    background: #11203a;
    transform: translateY(-2px);
  }
  .pd-nav-next {
    justify-content: flex-end;
    text-align: right;
  }

  .pd-nav-arrow {
    color: #4a9eff;
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .pd-nav-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .pd-nav-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
  }
  .pd-nav-title {
    color: #fff;
    font-weight: 600;
    font-size: 0.98rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Bildgalleri (separat från hero) */
  .pd-gallery {
    margin-top: clamp(2.5rem, 6vw, 4.5rem);
  }
  .pd-gallery h2 {
    font-family: 'Bebas Neue', system-ui, sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: 0.01em;
    margin: 0 0 1.5rem;
  }
  .pd-gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .pd-gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .pd-gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .pd-gallery-item {
    padding: 0;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0f172a;
    border-radius: 1rem;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 4 / 3;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .pd-gallery-item:hover {
    border-color: rgba(0, 120, 212, 0.55);
    transform: translateY(-3px);
    box-shadow: 0 18px 44px -16px rgba(0, 120, 212, 0.55);
  }
  .pd-gallery-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Lightbox – endast galleri-bilderna */
  .pd-lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(2, 6, 23, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .pd-lightbox.open {
    display: flex;
  }
  .pd-lb-img {
    max-width: min(92vw, 1100px);
    max-height: 86vh;
    object-fit: contain;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 30px 80px -20px rgba(0, 120, 212, 0.5);
  }
  .pd-lb-close,
  .pd-lb-nav {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    cursor: pointer;
    line-height: 1;
    transition: background 0.2s ease;
  }
  .pd-lb-close {
    top: 1.25rem;
    right: 1.5rem;
    width: 44px;
    height: 44px;
    font-size: 1.7rem;
  }
  .pd-lb-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }
  .pd-lb-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    font-size: 1.5rem;
  }
  .pd-lb-nav:hover {
    background: rgba(0, 120, 212, 0.6);
    border-color: rgba(0, 120, 212, 0.6);
  }
  .pd-lb-prev { left: 1rem; }
  .pd-lb-next { right: 1rem; }
  .pd-lb-counter {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    color: #cbd5e1;
    font-size: 0.85rem;
    font-weight: 600;
  }
</style>
